---
import type { MemoryGroup } from '@/lib/photo-ui';

interface Props {
  memory: MemoryGroup;
  variant: string;
}

const { memory, variant } = Astro.props;
---

<article class={`memory-card ${variant}`} data-testid="scale-memory-card">
  <a
    class="memory-photo"
    data-testid="scale-photo-link"
    href={`#scale-${memory.id}`}
    aria-label={`${memory.date} - ${memory.title} を大きく表示`}
  >
    <img
      src={memory.photo.src}
      alt={memory.photo.alt}
      width={memory.photo.width}
      height={memory.photo.height}
      loading="lazy"
    />
    <span class="photo-overlay">
      <span class="memory-title">
        <time datetime={memory.date}>{memory.date}</time> - {memory.title}
      </span>
      <span class="memory-note">{memory.note}</span>
    </span>
  </a>
</article>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { memoryGroups } from '@/lib/photo-ui';
---

<BaseLayout
  title="写真の記録"
  description="思い出の写真を1枚ずつ残すためのページです。"
>
  <section class="photo-hero" aria-labelledby="photo-title">
    <p class="eyebrow">Photo memories</p>
    <h1 id="photo-title">写真の記録</h1>
    <p class="lead">
      日付とタイトルを写真の上に重ね、思い出ごとに1枚だけを残す表示です。
      写真を開くと画面全体を覆うように大きく表示します。
    </p>
    <a class="scale-link" href="/photo-ui/scale/">写真が増えた時のUI案を見る</a>
  </section>

  <section id="memories" class="memory-grid" aria-label="思い出の写真一覧">
    {
      memoryGroups.map((memory, index) => (
        <article class="memory-card" data-testid="photo-memory">
          <a
            class="memory-photo"
            data-testid="memory-photo-link"
            href={`#${memory.id}`}
            aria-label={`${memory.date} - ${memory.title} を大きく表示`}
          >
            <img
              src={memory.photo.src}
              alt={memory.photo.alt}
              width={memory.photo.width}
              height={memory.photo.height}
              loading={index === 0 ? 'eager' : 'lazy'}
            />
            <span class="photo-overlay">
              <span class="memory-title">
                <time datetime={memory.date}>{memory.date}</time> - {memory.title}
              </span>
              <span class="memory-note">{memory.note}</span>
            </span>
          </a>
        </article>
      ))
    }
  </section>

  {
    memoryGroups.map((memory) => (
      <section
        class="photo-lightbox"
        id={memory.id}
        aria-labelledby={`${memory.id}-title`}
        data-testid="photo-lightbox"
      >
        <a class="lightbox-backdrop" href="/photo-ui/#memories" aria-label="背景をクリックして閉じる" />
        <div class="lightbox-panel" role="dialog" aria-modal="true">
          <div class="lightbox-heading">
            <h2 id={`${memory.id}-title`}>
              <time datetime={memory.date}>{memory.date}</time> - {memory.title}
            </h2>
            <a href="/photo-ui/#memories">閉じる</a>
          </div>
          <img
            src={memory.photo.src}
            alt={memory.photo.alt}
            width={memory.photo.width}
            height={memory.photo.height}
            loading="lazy"
          />
        </div>
      </section>
    ))
  }
</BaseLayout>

<style>
  :global(main) {
    max-width: 1280px;
  }

  .photo-hero {
    display: grid;
    gap: 0.85rem;
    margin-bottom: clamp(1.5rem, 4vw, 2.6rem);
    padding-bottom: clamp(1.1rem, 3vw, 2rem);
    border-bottom: 1px solid var(--line);
  }

  .photo-hero h1 {
    max-width: 8ch;
  }

  .scale-link {
    width: fit-content;
    padding: 0.55rem 0.8rem;
    background: var(--accent-strong);
    border-radius: 8px;
    color: #ffffff;
    font-weight: 800;
    text-decoration: none;
  }

  .memory-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 21rem), 1fr));
    gap: clamp(0.9rem, 2.5vw, 1.4rem);
  }

  .memory-card {
    min-width: 0;
  }

  .memory-photo {
    position: relative;
    display: block;
    min-height: clamp(17rem, 31vw, 25rem);
    overflow: hidden;
    background: #dcd5c8;
    border: 1px solid rgb(43 47 45 / 0.14);
    border-radius: 8px;
    box-shadow: 0 18px 44px rgb(41 35 25 / 0.12);
    color: #ffffff;
    text-decoration: none;
  }

  .memory-photo img {
    display: block;
    width: 100%;
    height: 100%;
    min-height: inherit;
    object-fit: cover;
    transition: transform 220ms ease;
  }

  .memory-photo:hover img,
  .memory-photo:focus-visible img {
    transform: scale(1.025);
  }

  .photo-overlay {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    display: grid;
    gap: 0.45rem;
    padding: clamp(0.9rem, 2.8vw, 1.2rem);
    background: linear-gradient(180deg, rgb(13 16 17 / 0), rgb(13 16 17 / 0.78));
  }

  .memory-title {
    font-size: clamp(1rem, 2vw, 1.28rem);
    font-weight: 800;
    line-height: 1.25;
  }

  .memory-title time {
    font-variant-numeric: tabular-nums;
  }

  .memory-note {
    max-width: 34rem;
    color: rgb(255 255 255 / 0.84);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .photo-lightbox {
    position: fixed;
    inset: 0;
    z-index: 50;
    display: none;
    place-items: center;
    padding: 0;
  }

  .photo-lightbox:target {
    display: grid;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgb(10 12 13 / 0.9);
  }

  .lightbox-panel {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: 100svh;
    min-height: 0;
  }

  .lightbox-heading {
    position: absolute;
    top: 0;
    right: 0;
    left: 0;
    z-index: 2;
    display: flex;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
    padding: clamp(1rem, 3vw, 1.5rem);
    background: linear-gradient(180deg, rgb(0 0 0 / 0.58), rgb(0 0 0 / 0));
    color: #ffffff;
  }

  .lightbox-heading h2 {
    margin: 0;
    font-size: clamp(1rem, 2vw, 1.35rem);
  }

  .lightbox-heading time {
    font-variant-numeric: tabular-nums;
  }

  .lightbox-heading a {
    flex: 0 0 auto;
    color: rgb(255 255 255 / 0.78);
    font-size: 0.92rem;
    text-decoration: none;
  }

  .lightbox-panel img {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 0;
    object-fit: contain;
    background: #050607;
  }

  @media (max-width: 640px) {
    .photo-hero h1 {
      max-width: 100%;
      font-size: clamp(2rem, 12vw, 3rem);
    }

    .memory-photo {
      min-height: 22rem;
    }

    .lightbox-heading {
      align-items: flex-start;
    }
  }
</style>

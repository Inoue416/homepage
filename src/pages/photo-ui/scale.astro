---
import PhotoScaleCard from '@/components/PhotoScaleCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { scaleMemoryGroups, scaleUiProposal } from '@/lib/photo-ui';

const memories = [...scaleMemoryGroups].sort((a, b) => b.date.localeCompare(a.date));
const latestMemory = memories[0];
const pastMemories = memories.slice(1);
---

<BaseLayout
  title="写真が増えた時の表示"
  description="写真の記録が増えた時に使う、最新重視の一覧UIです。"
>
  <section class="scale-hero" aria-labelledby="scale-title">
    <a class="back-link" href="/photo-ui/">写真の記録へ</a>
    <p class="eyebrow">Photo memories</p>
    <h1 id="scale-title">写真が増えた時の表示</h1>
    <p class="lead">
      案5の「最新を大きく、過去を小さく」を採用した表示です。
      写真は1つの思い出につき1枚、日付-タイトルは写真上に重ねます。
    </p>
  </section>

  <section
    id={scaleUiProposal.id}
    class="scale-proposal latest-spotlight"
    aria-labelledby="latest-spotlight-title"
    data-testid="scale-proposal"
  >
    <header class="proposal-heading">
      <p class="eyebrow">{scaleUiProposal.title}</p>
      <h2 id="latest-spotlight-title">{scaleUiProposal.shortTitle}</h2>
      <p>{scaleUiProposal.summary}</p>
      <strong>{scaleUiProposal.recommendation}</strong>
    </header>

    <div class="spotlight-layout">
      <div class="spotlight-main">
        <PhotoScaleCard memory={latestMemory} variant="spotlight" />
      </div>
      <div class="spotlight-list" aria-label="過去の写真">
        {pastMemories.map((memory) => <PhotoScaleCard memory={memory} variant="compact" />)}
      </div>
    </div>
  </section>

  {
    memories.map((memory) => (
      <section
        class="photo-lightbox"
        id={`scale-${memory.id}`}
        aria-labelledby={`scale-${memory.id}-title`}
        data-testid="scale-photo-lightbox"
      >
        <a
          class="lightbox-backdrop"
          href="/photo-ui/scale/#latest-spotlight"
          aria-label="背景をクリックして閉じる"
        />
        <div class="lightbox-panel" role="dialog" aria-modal="true">
          <div class="lightbox-heading">
            <h2 id={`scale-${memory.id}-title`}>
              <time datetime={memory.date}>{memory.date}</time> - {memory.title}
            </h2>
            <a href="/photo-ui/scale/#latest-spotlight">閉じる</a>
          </div>
          <img
            src={memory.photo.src}
            alt={memory.photo.alt}
            width={memory.photo.width}
            height={memory.photo.height}
            loading="lazy"
          />
        </div>
      </section>
    ))
  }
</BaseLayout>

<style is:global>
  main {
    max-width: 1280px;
  }

  .scale-hero {
    display: grid;
    gap: 0.85rem;
    margin-bottom: clamp(1.2rem, 3vw, 2rem);
    padding-bottom: clamp(1rem, 3vw, 1.7rem);
    border-bottom: 1px solid var(--line);
  }

  .scale-hero h1 {
    max-width: 11ch;
  }

  .back-link {
    width: fit-content;
    color: var(--muted);
    font-size: 0.92rem;
    text-decoration: none;
  }

  .scale-proposal {
    display: grid;
    gap: 1rem;
    padding: clamp(1rem, 2.6vw, 1.35rem);
    background: color-mix(in srgb, var(--surface) 72%, var(--bg));
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  .proposal-heading {
    display: grid;
    gap: 0.55rem;
    max-width: 58rem;
  }

  .proposal-heading h2 {
    margin: 0;
  }

  .proposal-heading p {
    margin: 0;
    color: var(--muted);
  }

  .proposal-heading strong {
    color: var(--accent-strong);
  }

  .memory-card {
    min-width: 0;
  }

  .memory-photo {
    position: relative;
    display: block;
    min-height: 15rem;
    overflow: hidden;
    background: #dcd5c8;
    border: 1px solid rgb(43 47 45 / 0.14);
    border-radius: 8px;
    color: #ffffff;
    text-decoration: none;
  }

  .memory-photo img {
    display: block;
    width: 100%;
    height: 100%;
    min-height: inherit;
    object-fit: cover;
    transition: transform 220ms ease;
  }

  .memory-photo:hover img,
  .memory-photo:focus-visible img {
    transform: scale(1.025);
  }

  .photo-overlay {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    display: grid;
    gap: 0.35rem;
    padding: 0.85rem;
    background: linear-gradient(180deg, rgb(13 16 17 / 0), rgb(13 16 17 / 0.78));
  }

  .memory-title {
    font-size: 0.96rem;
    font-weight: 800;
    line-height: 1.25;
  }

  .memory-title time {
    font-variant-numeric: tabular-nums;
  }

  .memory-note {
    color: rgb(255 255 255 / 0.82);
    font-size: 0.78rem;
    line-height: 1.45;
  }

  .spotlight-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.86fr) minmax(18rem, 0.54fr);
    gap: 1rem;
    align-items: start;
  }

  .spotlight-main .memory-photo {
    min-height: clamp(24rem, 46vw, 36rem);
  }

  .spotlight-main .memory-title {
    font-size: clamp(1.1rem, 2vw, 1.45rem);
  }

  .spotlight-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.65rem;
  }

  .spotlight-list .memory-photo {
    min-height: 11rem;
  }

  .spotlight-list .memory-note {
    display: none;
  }

  .photo-lightbox {
    position: fixed;
    inset: 0;
    z-index: 50;
    display: none;
    place-items: center;
    padding: 0;
  }

  .photo-lightbox:target {
    display: grid;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgb(10 12 13 / 0.9);
  }

  .lightbox-panel {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: 100svh;
  }

  .lightbox-heading {
    position: absolute;
    top: 0;
    right: 0;
    left: 0;
    z-index: 2;
    display: flex;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
    padding: clamp(1rem, 3vw, 1.5rem);
    background: linear-gradient(180deg, rgb(0 0 0 / 0.58), rgb(0 0 0 / 0));
    color: #ffffff;
  }

  .lightbox-heading h2 {
    margin: 0;
    font-size: clamp(1rem, 2vw, 1.35rem);
  }

  .lightbox-heading a {
    flex: 0 0 auto;
    color: rgb(255 255 255 / 0.78);
    font-size: 0.92rem;
    text-decoration: none;
  }

  .lightbox-panel img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: #050607;
  }

  @media (max-width: 820px) {
    .scale-hero h1 {
      max-width: 100%;
      font-size: clamp(2rem, 12vw, 3rem);
    }

    .spotlight-layout {
      grid-template-columns: 1fr;
    }

    .spotlight-list {
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 10rem), 1fr));
    }
  }
</style>

---
import { getCollection } from 'astro:content';
import EntryList from '@/components/EntryList.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { byNewest, isPublished, sectionDescriptions, sectionLabels } from '@/lib/content';

const section = 'books';
const entries = (await getCollection(section)).filter(isPublished).sort(byNewest);
---

<BaseLayout
  title={sectionLabels[section]}
  description={sectionDescriptions[section]}
>
  <section class="section-header">
    <p class="eyebrow">Books</p>
    <h1>{sectionLabels[section]}</h1>
    <p class="lead">{sectionDescriptions[section]}</p>
  </section>
  <EntryList entries={entries} section={section} />
</BaseLayout>

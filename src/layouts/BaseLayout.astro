---
import '@/styles/global.css';
import { site } from '@/site.config';

interface Props {
  title?: string;
  description?: string;
}

const pageTitle = Astro.props.title ? `${Astro.props.title} | ${site.title}` : site.title;
const description = Astro.props.description ?? site.description;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={site.title}
      href="/rss.xml"
    />
    <title>{pageTitle}</title>
  </head>
  <body class="antialiased">
    <header class="site-header">
      <a class="brand" href="/" aria-label={`${site.title} のトップへ`}
        >{site.title}</a
      >
      <nav aria-label="Primary navigation">
        <a href="/blog/">ブログ</a>
        <a href="/projects/">作ったもの</a>
        <a href="/notes/">勉強メモ</a>
        <a href="/books/">書籍メモ</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>&copy; {new Date().getFullYear()} {site.author}</p>
    </footer>
  </body>
</html>
